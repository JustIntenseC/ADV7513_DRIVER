 489:Core/Src/main.c **** void ADV7513_WriteVerifyReg(uint8_t reg_addr, uint8_t reg_value, const char* reg_name)
 490:Core/Src/main.c **** {
 491:Core/Src/main.c ****     HAL_StatusTypeDef status;
 492:Core/Src/main.c ****     uint8_t write_val = reg_value;
 493:Core/Src/main.c ****     uint8_t read_val = 0;
 494:Core/Src/main.c **** 
 495:Core/Src/main.c ****     // Запись
 496:Core/Src/main.c ****     status = HAL_I2C_Mem_Write(&hi2c1, ADV7513_ADDR, reg_addr, I2C_MEMADD_SIZE_8BIT, &write_val, 1,
 497:Core/Src/main.c ****     if(status != HAL_OK) {
 498:Core/Src/main.c ****         HAL_UART_Transmit(&huart1, (uint8_t*)reg_name, strlen(reg_name), HAL_MAX_DELAY);
 499:Core/Src/main.c ****         HAL_UART_Transmit(&huart1, (uint8_t*)" Write ERROR\n", 13, HAL_MAX_DELAY);
 500:Core/Src/main.c ****         Error_Handler();
 501:Core/Src/main.c ****     }
 502:Core/Src/main.c **** 
 503:Core/Src/main.c ****     // Чтение
 504:Core/Src/main.c ****     status = HAL_I2C_Mem_Read(&hi2c1, ADV7513_ADDR, reg_addr, I2C_MEMADD_SIZE_8BIT, &read_val, 1, H
 505:Core/Src/main.c ****     if(status != HAL_OK) {
 506:Core/Src/main.c ****         HAL_UART_Transmit(&huart1, (uint8_t*)reg_name, strlen(reg_name), HAL_MAX_DELAY);
 507:Core/Src/main.c ****         HAL_UART_Transmit(&huart1, (uint8_t*)" Read ERROR\n", 12, HAL_MAX_DELAY);
 508:Core/Src/main.c ****         Error_Handler();
 509:Core/Src/main.c ****     }
 510:Core/Src/main.c **** 
 511:Core/Src/main.c ****     // Проверка
 512:Core/Src/main.c ****     if(read_val != reg_value) {
 513:Core/Src/main.c ****         HAL_UART_Transmit(&huart1, (uint8_t*)reg_name, strlen(reg_name), HAL_MAX_DELAY);
 514:Core/Src/main.c ****         HAL_UART_Transmit(&huart1, (uint8_t*)" Verify FAIL\n", 13, HAL_MAX_DELAY);
 515:Core/Src/main.c ****         Error_Handler();
 516:Core/Src/main.c ****     } else {
 517:Core/Src/main.c ****         HAL_UART_Transmit(&huart1, (uint8_t*)reg_name, strlen(reg_name), HAL_MAX_DELAY);
 518:Core/Src/main.c ****         HAL_UART_Transmit(&huart1, (uint8_t*)" => OK\n", 7, HAL_MAX_DELAY);
ARM GAS  /var/folders/l4/6w9kflz11csb_6qsyz46nv3c0000gp/T//ccC1dtku.s 			page 12


 519:Core/Src/main.c ****     }
 520:Core/Src/main.c **** }
